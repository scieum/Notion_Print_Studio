# Notion public integration (https://www.notion.so/my-integrations)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# 로컬: http://localhost:3001/auth/notion/callback
# 프로덕션(Vercel): https://<your-app>.vercel.app/auth/notion/callback
NOTION_REDIRECT_URI=http://localhost:3001/auth/notion/callback

# DB — Turso(libSQL). 비워두면 로컬 파일 SQLite(file:./data/nps.sqlite)로 폴백.
# Vercel 등 서버리스에서는 반드시 채워야 한다 (디스크가 임시라 파일 SQLite는 유실됨).
# turso db create / turso db show --url / turso db tokens create 로 발급
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 서버 (로컬 실행 전용 — Vercel에서는 무시)
PORT=3001
DATA_DIR=./data

# 로컬에서 시스템 Chrome로 PDF 렌더 시 실행 경로 지정 (Vercel에서는 @sparticuz/chromium 자동 사용)
# 예: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_EXECUTABLE_PATH=

# Puppeteer 렌더 동시성 상한 (불변 제약 C7 — 기본 2, 서버리스에선 함수 동시성이 대체)
RENDER_CONCURRENCY=2
